{
  "datasets": [
    {
      "name": "kpi",
      "displayName": "KPIs",
      "queryLines": [
        "\n        SELECT count(*) total,\n               sum(CASE WHEN valid_status IN ('pass','unresolved_ext_dep','sound_dep') THEN 1 ELSE 0 END) success,\n               round(100.0*sum(CASE WHEN valid_status IN ('pass','unresolved_ext_dep','sound_dep') THEN 1 ELSE 0 END)/count(*),1) pct_success,\n               sum(CASE WHEN valid_status IN ('fail','timeout') THEN 1 ELSE 0 END) needs_review\n        FROM (SELECT * FROM main.tsql_migration.validation_results WHERE run_ts=(SELECT max(run_ts) FROM main.tsql_migration.validation_results WHERE fraction=(SELECT max(fraction) FROM main.tsql_migration.validation_results))) v"
      ]
    },
    {
      "name": "funnel",
      "displayName": "Reconciliation funnel",
      "queryLines": [
        "SELECT object_type, source_n, converted_n, validated_n, success_n FROM main.tsql_migration.recon_inventory ORDER BY object_type"
      ]
    },
    {
      "name": "bytype",
      "displayName": "Status by type",
      "queryLines": [
        "\n        SELECT object_type, CASE WHEN valid_status='pass' THEN '1 pass'\n               WHEN valid_status IN ('unresolved_ext_dep','sound_dep') THEN '2 sound (dep)'\n               WHEN valid_status='timeout' THEN '3 timeout' ELSE '4 fail' END status, count(*) n\n        FROM (SELECT * FROM main.tsql_migration.validation_results WHERE run_ts=(SELECT max(run_ts) FROM main.tsql_migration.validation_results WHERE fraction=(SELECT max(fraction) FROM main.tsql_migration.validation_results))) v GROUP BY 1,2 ORDER BY 1,2"
      ]
    },
    {
      "name": "rollout",
      "displayName": "Staged rollout",
      "queryLines": [
        "\n        SELECT cast(fraction as string) fraction, round(100.0*sum(success)/sum(n),1) pct_success, sum(n) n\n        FROM main.tsql_migration.run_summary GROUP BY fraction ORDER BY fraction"
      ]
    },
    {
      "name": "errclass",
      "displayName": "Failure classes",
      "queryLines": [
        "\n        SELECT CASE WHEN valid_error LIKE '%PARSE_SYNTAX_ERROR%' THEN 'parse syntax'\n                    WHEN valid_error LIKE '%PYTHON_SYNTAX%' THEN 'python syntax'\n                    WHEN valid_error LIKE '%UNRESOLVED_COLUMN%' THEN 'unresolved column'\n                    WHEN valid_error LIKE '%IDENTIFIER_TOO_MANY_NAME_PARTS%' THEN 'cross-db 3-part name'\n                    WHEN valid_error LIKE '%UNRESOLVABLE_TABLE_VALUED_FUNCTION%' THEN 'TVF unresolved'\n                    WHEN valid_status='timeout' THEN 'timeout (transient)' ELSE 'other' END errclass, count(*) n\n        FROM (SELECT * FROM main.tsql_migration.validation_results WHERE run_ts=(SELECT max(run_ts) FROM main.tsql_migration.validation_results WHERE fraction=(SELECT max(fraction) FROM main.tsql_migration.validation_results))) v WHERE valid_status IN ('fail','timeout') GROUP BY 1"
      ]
    },
    {
      "name": "review",
      "displayName": "Needs review",
      "queryLines": [
        "\n        SELECT object_type, full_name, substr(regexp_replace(valid_error,'[\\n]',' '),1,220) error\n        FROM (SELECT * FROM main.tsql_migration.validation_results WHERE run_ts=(SELECT max(run_ts) FROM main.tsql_migration.validation_results WHERE fraction=(SELECT max(fraction) FROM main.tsql_migration.validation_results))) v WHERE valid_status IN ('fail','timeout') ORDER BY object_type, full_name"
      ]
    }
  ],
